exec --no-startup-id /usr/libexec/xdg-desktop-portal
exec --no-startup-id /usr/libexec/xdg-desktop-portal-wlr
exec --no-startup-id wireplumber
exec --no-startup-id pactl load-module module-suspend-on-idle
exec autotiling
exec --no-startup-id $term

#Keyboard layout
input 1:1:AT_Translated_Set_2_keyboard {
#  events disabled
  xkb_layout "ee"
#  xkb_options caps:super
  xkb_options ctrl:nocaps
}

input 1278:37:PFU_Limited_HHKB-Classic {
    xkb_layout "us, ee"
    xkb_options grp:win_space_toggle,Super_L:super
  }
# Mouse cursor
seat * xcursor_theme whiteglass 24
seat * hide_cursor 4000

# Touchpad
input "1267:12680:ELAN0673:00_04F3:3188_Touchpad" {
	dwt enabled
	tap enabled
	middle_emulation enabled
	accel_profile "flat"
	pointer_accel 0.2
}

# Trackpoint
input "2:10:TPPS/2_Elan_TrackPoint" {
	dwt enabled
	pointer_accel -0.4
	scroll_factor 0.3
}

## usb mouse
#input "2362:9505:USB_OPTICAL_MOUSE" {
#  dwt enabled
#  pointer_accel -0.8
#}

# Display
# swaymsg -t get_outputs annab nimekirja monitoridest
#workspace 1 output eDP-1
output eDP-1 disable
output eDP-1 {
  resolution 3840x2400@60Hz
	position 1920,0
	scale 2.2
	adaptive_sync on
}

# Jõhvi monitor
workspace 2 output DP-6
output DP-6 {
	resolution 1920x1080
	scale 1
  transform 270
}

workspace 1 output DP-8
output DP-8 {
  resolution 1920x1080
  scale 1
  #transform 270
}

for_window [class=".*"] allow_tearing  no
# Wallpaper

exec swaybg -c "#0e1d21"

# Logo key. Use Mod1 for Alt or Mod4 for window key
set $mod Mod4

#Screen Brightness
	bindsym XF86MonBrightnessDown exec xbacklight -dec 1
	bindsym XF86MonBrightnessUp exec xbacklight -inc 1
  bindsym Shift+$mod+S exec xbacklight -inc 1
  bindsym Shift+$mod+A exec xbacklight -dec 1
	# Volume control
  bindsym $mod+s exec amixer sset Master 5%+
	bindsym XF86AudioRaiseVolume exec amixer sset Master 5%+ 
	bindsym $mod+a exec amixer sset Master 5%-
  bindsym XF86AudioLowerVolume exec amixer sset Master 5%- 
  bindsym $mod+d exec amixer sset Master toggle
	bindsym XF86AudioMute exec amixer sset Master toggle
  bindsym $mod+f exec amixer sset Capture toggle
	bindsym XF86AudioMicMute exec amixer sset Capture toggle

# System shortcuts
	# Reload the configuration file
	bindsym $mod+Shift+c reload

	# Kill focused window
	bindsym $mod+q kill

	# Exit sway (logs you out of your Wayland session)
	bindsym $mod+Escape exec swaynag -t warning -m ' ' -B 'Exit sway' 'swaymsg exit'


# SwayFX effects
titlebar_border_thickness 1
default_border none
default_floating_border none
smart_borders on
shadows enable
shadow_blur_radius 1
shadow_offset 4 4
default_dim_inactive 0.3
corner_radius 8
gaps inner 12
gaps outer 0
smart_gaps on


# GTK theme setup
# Themes are located in ~/.themes/
set $gnome-schema org.gnome.desktop.interface
exec_always {
    gsettings set $gnome-schema text-scaling-factor 1
    gsettings set $gnome-schema gtk-theme 'Skeuos-Black-Light'
    gsettings set $gnome-schema icon-theme 'Gruvbox-Plus-Light'
    gsettings set $gnome-schema cursor-theme 'whiteglass'
    gsettings set $gnome-schema cursos-theme-size 38
    gsettings set $gnome-schema font-name 'Inconsoloata 13'
#    gsettings set $gnome-schema font-name 'Iosevka 11'
}

# Define programs
set $term alacritty
set $editor $term -e vim
set $filebrowser thunar

# Signal
bindsym XF86NotificationCenter exec signal-desktop

# Start a terminal
bindsym $mod+Return exec $term
bindsym $mod+Shift+Return exec $term -e tmux

# Screenshot
bindsym Print exec 'shotman -c output -C'
bindsym Shift+Print exec 'shotman -c region -C'

# Firefox
bindsym $mod+F12 exec 'firefox-wayland -P default'
bindsym XF86Favorites exec 'firefox-wayland -P default'
#bindsym XF86Favorites exec 'firejail firefox-wayland --no-remote'
for_window [title = "About Mozilla Firefox"] floating enable
for_window [app_id="firefox" title="Library"] floating enable, border pixel 1, sticky enable
for_window [app_id="firefox" title="Downloads"] floating enable, border pixel 1, sticky enable

#Tor
bindsym $mod+Shift+F12 exec 'export QT_QPA_PLATFORM=xcb && torbrowser-launcher'
for_window [title = "About Tor"] floating enable
for_window [app_id="torbrowser" title="Library"] floating enable, border pixel 1, sticky enable
for_window [app_id="torbrowser" title="Downloads"] floating enable, border pixel 1, sticky enable


bindsym Shift+XF86Favorites exec 'chromium --enable-features=UseOzonePlatform --enable-gpu --ozone-platform=wayland'
# Floating windows
for_window [title="Thunar"] floating enable
for_window [app_id="Thunar" title="^Copying.*"] floating enable

# Start program launcher
bindsym $mod+Tab exec $menu

# Thunar
bindsym $mod+t exec thunar

# Your preferred application launcher
# Note: pass the final command to swaymsg so that the resulting window can be opened
# on the original workspace that the command was run on.
set $menu wmenu-run -f 'PragmataPro 18' -b -i
### Idle configuration
# Example configuration:
#exec swayidle -w \
#    timeout 300 'swaylock -f -c 0e1d21 -u' \
#    timeout 600 'swaymsg "output * dpms off"' \
#         resume 'swaymsg "output * dpms on"' \
#    before-sleep 'swaylock -f -c 0e1d21 -u'

bindsym XF86Display exec 'swaylock -e -F -c000000 --font PragmataPro --font-size 32'
bindsym Shift+$mod+d exec 'swaylock -e -F -c000000 --font PragmataPro --font-size 32'

# This will lock your screen after 300 seconds of inactivity, then turn off
# your displays after another 300 seconds, and turn your screens back on when
# resumed. It will also lock your screen before your computer goes to sleep.

#
# You can get the names of your inputs by running: swaymsg -t get_inputs
# Read `man 5 sway-input` for more information about this section.



#Shorts
    # Drag floating windows by holding down $mod and left mouse button.
    # Resize them with right mouse button + $mod.
    # Despite the name, also works for non-floating windows.
    # Change normal to inverse to use left mouse button for resizing and right
    # mouse button for dragging.
    floating_modifier $mod normal


# Moving around

# Home row direction keys, like vim
    set $left h
    set $down j
    set $up k
    set $right l

# Move your focus around
    bindsym $mod+$left focus left
    bindsym $mod+$down focus down
    bindsym $mod+$up focus up
    bindsym $mod+$right focus right
    # Or use $mod+[up|down|left|right]
    bindsym $mod+Left focus left
    bindsym $mod+Down focus down
    bindsym $mod+Up focus up
    bindsym $mod+Right focus right

# Move the focused window with the same, but add Shift
    bindsym $mod+Shift+$left move left
    bindsym $mod+Shift+$down move down
    bindsym $mod+Shift+$up move up
    bindsym $mod+Shift+$right move right
    # Ditto, with arrow keys
    bindsym $mod+Shift+Left move left
    bindsym $mod+Shift+Down move down
    bindsym $mod+Shift+Up move up
    bindsym $mod+Shift+Right move right

# Workspaces:
    # Switch to workspace
    bindsym $mod+1 workspace number 1
    bindsym $mod+2 workspace number 2
    bindsym $mod+3 workspace number 3
    bindsym $mod+4 workspace number 4
    bindsym $mod+5 workspace number 5
    bindsym $mod+6 workspace number 6
    bindsym $mod+7 workspace number 7
    bindsym $mod+8 workspace number 8
    bindsym $mod+9 workspace number 9
    bindsym $mod+0 workspace number 10
    # Move focused container to workspace
    bindsym $mod+Shift+1 move container to workspace number 1
    bindsym $mod+Shift+2 move container to workspace number 2
    bindsym $mod+Shift+3 move container to workspace number 3
    bindsym $mod+Shift+4 move container to workspace number 4
    bindsym $mod+Shift+5 move container to workspace number 5
    bindsym $mod+Shift+6 move container to workspace number 6
    bindsym $mod+Shift+7 move container to workspace number 7
    bindsym $mod+Shift+8 move container to workspace number 8
    bindsym $mod+Shift+9 move container to workspace number 9
    bindsym $mod+Shift+0 move container to workspace number 10


# Layout stuff:

# You can "split" the current object of your focus with
    # $mod+b or $mod+v, for horizontal and vertical splits
    # respectively.
    bindsym $mod+b splith
    bindsym $mod+v splitv

    # Switch the current container between different layout styles
    #bindsym $mod+s layout stacking
    bindsym $mod+w layout tabbed
    bindsym $mod+e layout toggle split

    # Make the current focus fullscreen
    bindsym $mod+o fullscreen

    # Toggle the current focus between tiling and floating mode
    bindsym $mod+Shift+space floating toggle

    # Swap focus between the tiling area and the floating area
    #bindsym $mod+space focus mode_toggle

    # Move focus to the parent container
    #bindsym $mod+a focus parent


# Scratchpad:

    # Sway has a "scratchpad", which is a bag of holding for windows.
    # You can send windows there and get them back later.

    # Move the currently focused window to the scratchpad
    bindsym $mod+Shift+minus move scratchpad

    # Show the next scratchpad window or hide the focused scratchpad window.
    # If there are multiple scratchpad windows, this command cycles through them.
    bindsym $mod+minus scratchpad show
#
# Resizing containers:
#
mode "resize" {
    # left will shrink the containers width
    # right will grow the containers width
    # up will shrink the containers height
    # down will grow the containers height
    bindsym $left resize shrink width 30px
    bindsym $down resize grow height 30px
    bindsym $up resize shrink height 30px
    bindsym $right resize grow width 30px

    # Ditto, with arrow keys
    bindsym Left resize shrink width 10px
    bindsym Down resize grow height 10px
    bindsym Up resize shrink height 10px
    bindsym Right resize grow width 10px

    # Return to default mode
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

bar {
    id default
    mode hide
    font PragmataPro:Bold 14
    position bottom
    status_command while ~/.config/sway/status.sh; do sleep 1; done
    colors {
        statusline #e4e8e9
        background #010909
        inactive_workspace #010909 #010909 #f5f5f5
 }
}
